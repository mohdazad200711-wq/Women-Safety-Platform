# Rename to .env and set your MongoDB connection string

# Local MongoDB
# MONGO_URI=mongodb://localhost:27017/woman-safety

# MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/woman-safety?retryWrites=true&w=majority

PORT=5000
JWT_SECRET=your_jwt_secret_key_here
